{
  "name": "@personal-library/react-native-components",
  "version": "0.0.0",
  "description": "Personal Library React Native Components.",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsc -p tsconfig.json --watch --noEmit",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "build:prod": "npm run clean && npm run typecheck && npm run build",
    "package:dry-run": "npm pack --dry-run",
    "clean": "rm -rf dist *.tgz",
    "prepack:check": "npm run build:prod && npm run package:dry-run",
    "release:check": "npm run clean && npm ci && npm run typecheck && npm run build && npm run package:dry-run"
  },
  "engines": {
    "node": ">=22"
  },
  "peerDependencies": {
    "react": ">=19.2.3 <20.0.0",
    "react-native": ">=0.85.0 <0.86.0"
  },
  "devDependencies": {
    "typescript": "^5.8.0"
  }
}
